modules = ["nodejs-20"]
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]
run = "node --enable-source-maps dist/index.js"

[nix]
channel = "stable-24_05"

[deployment]
run = ["node", "--enable-source-maps", "dist/index.js"]
deploymentTarget = "cloudrun"
build = ["bash", "deploy.sh"]

[[ports]]
localPort = 5000
externalPort = 80

